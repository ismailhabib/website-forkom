---
import Features3 from '~/components/widgets/Features3.astro';
import Hero from '~/components/widgets/Hero.astro';
import Stats from '~/components/widgets/Stats.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Tentang Kami',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    tagline="Tentang Kami"
    image={{
      src: 'https://images.unsplash.com/photo-1559136555-9303baea8ebd?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80',
      alt: 'About Us Image',
    }}
  >
    <Fragment slot="title">
      Forum Komunikasi <br />
      <span class="text-accent dark:text-white">Komunitas Muslim Indonesia di Belanda</span>
    </Fragment>

    <Fragment slot="subtitle">
      FORKOM NL adalah wadah komunikasi untuk berbagai komunitas Muslim Indonesia yang tersebar di seluruh Belanda. Kami
      hadir sebagai platform untuk kolaborasi, advokasi, dan pemberdayaan bagi organisasi anggota kami.
    </Fragment>
  </Hero>

  <!-- Stats Widget ****************** -->

  <Stats
    title="Forkom Dalam Angka"
    stats={[
      { title: 'Organisasi Anggota', amount: '13' },
      { title: 'Jumlah Anggota', amount: '500+' },
    ]}
  />

  <!-- Steps2 Widget ****************** -->

  <Steps2
    title="Visi & Misi"
    subtitle="Landasan pergerakan dan cita-cita kami."
    items={[
      {
        title: 'Visi',
        description:
          'Terwujudnya peran aktif dan kontribusi positif umat Islam Indonesia di Belanda untuk masyarakat Indonesia di Belanda, umat Islam di Belanda, dan masyarakat Belanda secara keseluruhan.',
      },
      {
        title: 'Misi: Diplomasi & Advokasi',
        description: 'Menjadi suara perwakilan umat Islam Indonesia di Belanda.',
      },
      {
        title: 'Misi: Pemberdayaan Anggota',
        description: 'Memajukan seluruh komunitas Islam anggota melalui program pengembangan organisasi.',
      },
      {
        title: 'Misi: Kajian Strategis',
        description: 'Menyelenggarakan diskusi dengan tema strategis dan kontemporer bersama narasumber yang kompeten.',
      },
    ]}
  />

  <!-- Features3 Widget ************** -->

  <Features3
    title="Anggota Komunitas"
    subtitle="Organisasi yang tergabung dalam FORKOM NL."
    columns={3}
    items={[
      {
        title: 'DeGromiest Groningen',
        description: 'Organisasi Muslim di Groningen, terdiri dari pelajar dan warga tetap Indonesia.',
        icon: 'tabler:users',
      },
      {
        title: 'IMEA Enschede',
        description: 'Indonesian Muslim Enschede Association, pusat kajian rutin di Enschede.',
        icon: 'tabler:users',
      },
      {
        title: 'Wageningen',
        description: 'Komunitas pengajian warga dan mahasiswa Indonesia di kota Wageningen.',
        icon: 'tabler:users',
      },
      {
        title: 'Ede',
        description: 'Kelompok kajian yang sering beraktivitas di Masjid Al-Mouahiddin, Ede.',
        icon: 'tabler:users',
      },
      {
        title: 'SGB Utrecht',
        description: 'Stichting Generasi Baru, yayasan Muslim Indonesia di Utrecht yang aktif secara nasional.',
        icon: 'tabler:users',
      },
      {
        title: 'KMD Delft',
        description: 'Keluarga Muslim Delft, komunitas bagi warga dan pelajar di Delft.',
        icon: 'tabler:users',
      },
      {
        title: 'Musihoven Eindhoven',
        description: 'Stichting Musihoven, yayasan Muslim Indonesia yang berbasis di Eindhoven.',
        icon: 'tabler:users',
      },
      {
        title: 'KAMIL Maastricht',
        description: 'Keluarga Muslim Indonesia Limburg, berbasis di kota Maastricht.',
        icon: 'tabler:users',
      },
      {
        title: 'PPMR Rotterdam',
        description: 'Persatuan Pelajar Muslim Rotterdam, organisasi khusus pelajar Muslim di Rotterdam.',
        icon: 'tabler:users',
      },
      {
        title: 'Tilburg',
        description: 'Komunitas Muslim Indonesia yang sering berkolaborasi dengan Masjid As-Sunnah, Tilburg.',
        icon: 'tabler:users',
      },
      {
        title: 'IKRAM Arnhem',
        description: 'Ikatan Keluarga Muslim Arnhem, wadah silaturahmi warga Indonesia di Arnhem.',
        icon: 'tabler:users',
      },
      {
        title: 'Amersfoort',
        description: 'Kelompok pengajian warga Indonesia di Amersfoort (sering bersifat lokal/rumah ke rumah).',
        icon: 'tabler:users',
      },
      {
        title: 'KEMUNI Nijmegen',
        description: 'Keluarga Muslim Indonesia Nijmegen, komunitas pengajian warga dan pelajar di Nijmegen.',
        icon: 'tabler:users',
      },
    ]}
  />
</Layout>
